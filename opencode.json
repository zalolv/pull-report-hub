{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "copilot": {
      "enabled": true
    }
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    }
  },
  "autoupdate": true
}
